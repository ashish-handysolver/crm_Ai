rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: recordings
    // Document ID: uuid (8 chars)
    // Fields:
    //   - id: string (required) - Unique identifier for the recording.
    //   - audioData: string (required) - Base64 encoded audio data.
    //   - transcript: string (required) - AI-generated transcript of the audio.
    //   - createdAt: timestamp (required) - When the recording was created.
    //   - authorUid: string (required) - The UID of the user who created the recording.
    //   - meetingId: string (optional) - ID of the meeting this recording belongs to.
    //
    // Collection: meetings
    // Document ID: uuid (8 chars)
    // Fields:
    //   - id: string (required) - Unique identifier for the meeting.
    //   - title: string (required) - Title of the meeting.
    //   - ownerUid: string (required) - The UID of the user who created the meeting.
    //   - createdAt: timestamp (required) - When the meeting was created.
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ashish.handysolver@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidRecording(data) {
      return hasRequiredFields(['id', 'audioData', 'transcript', 'createdAt', 'authorUid']) &&
             hasOnlyAllowedFields(['id', 'audioData', 'transcript', 'createdAt', 'authorUid', 'meetingId']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.audioData is string && data.audioData.size() > 0 &&
             data.transcript is string &&
             data.createdAt is timestamp &&
             data.authorUid is string &&
             (!('meetingId' in data) || (data.meetingId is string && data.meetingId.size() < 50));
    }

    function isValidMeeting(data) {
      return hasRequiredFields(['id', 'title', 'ownerUid', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'title', 'ownerUid', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerUid is string &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /recordings/{recordingId} {
      // Allow anyone to view a specific recording if they have the ID (for sharing)
      allow get: if true;
      
      // Only allow the owner to list their own recordings (for history)
      // OR allow listing if filtering by a meeting the user owns
      allow list: if isAuthenticated() && 
                   (
                     (request.query.authorUid == request.auth.uid) ||
                     (request.query.meetingId != null) // Meeting-specific listing logic
                   );

      // Allow authenticated users to create recordings
      // OR allow guests to create recordings if they are part of a meeting
      allow create: if isValidRecording(request.resource.data) && 
                    (
                      (isAuthenticated() && request.resource.data.authorUid == request.auth.uid) ||
                      (request.resource.data.meetingId != null)
                    );
      
      // Only owner can update or delete
      allow update: if isOwner(resource.data.authorUid) && isValidRecording(request.resource.data);
      allow delete: if isOwner(resource.data.authorUid) || isAdmin();
    }

    match /meetings/{meetingId} {
      allow get: if true; // Anyone with the link can "join" the meeting room
      allow list: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid && isValidMeeting(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerUid == request.auth.uid && isValidMeeting(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Users can only create their own profile as 'user' role, unless they are already admin
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && (request.resource.data.role == 'user' || isAdmin()));
      // Only admins can change roles
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    // Placeholder for Leads if requested
    match /leads/{leadId} {
      allow read, write: if isAuthenticated();
    }
  }
}
