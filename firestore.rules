rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: recordings
    // Document ID: uuid (8 chars)
    // Fields:
    //   - id: string (required) - Unique identifier for the recording.
    //   - audioData: string (required) - Base64 encoded audio data.
    //   - transcript: string (required) - AI-generated transcript of the audio.
    //   - createdAt: timestamp (required) - When the recording was created.
    //   - authorUid: string (required) - The UID of the user who created the recording.
    //   - meetingId: string (optional) - ID of the meeting this recording belongs to.
    //
    // Collection: meetings
    // Document ID: uuid (8 chars)
    // Fields:
    //   - id: string (required) - Unique identifier for the meeting.
    //   - title: string (required) - Title of the meeting.
    //   - ownerUid: string (required) - The UID of the user who created the meeting.
    //   - createdAt: timestamp (required) - When the meeting was created.
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ashish.handysolver@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidRecording(data) {
      return hasRequiredFields(['id', 'audioData', 'transcript', 'createdAt', 'authorUid']) &&
             hasOnlyAllowedFields(['id', 'audioData', 'transcript', 'createdAt', 'authorUid', 'meetingId', 'leadId']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.audioData is string && data.audioData.size() > 0 &&
             data.transcript is string &&
             data.createdAt is timestamp &&
             data.authorUid is string &&
             (!('meetingId' in data) || (data.meetingId is string && data.meetingId.size() < 50)) &&
             (!('leadId' in data) || (data.leadId is string && data.leadId.size() < 50));
    }

    function isValidMeeting(data) {
      return hasRequiredFields(['id', 'title', 'ownerUid', 'createdAt']) &&
             // Allow leadId so we can map guest recordings to the right lead
             hasOnlyAllowedFields(['id', 'title', 'ownerUid', 'createdAt', 'leadId']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerUid is string &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
         request.auth.token.email == "ashish.handysolver@gmail.com" ||
         request.auth.token.email == "admin@handysolver.com");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /recordings/{recordingId} {
      allow read: if true;
      allow write: if isAuthenticated() || (request.resource.data.meetingId != null || request.resource.data.leadId != null);
      allow delete: if isSuperAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId);
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated() && (resource.data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId || isSuperAdmin());
      allow write: if isAuthenticated();
    }

    match /custom_fields/{fieldId} {
      allow read, write: if isAuthenticated();
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.createdBy || isSuperAdmin());
      allow write: if isAuthenticated();
    }
  }
}
